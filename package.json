{
  "name": "todo-vibe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:proxy": "set HTTP_PROXY=http://127.0.0.1:7897&& set HTTPS_PROXY=http://127.0.0.1:7897&& next dev --webpack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --pool=threads",
