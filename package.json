    "@supabase/supabase-js": "^2.99.3",
    "antd": "^6.3.2",
    "framer-motion": "^12.38.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.16",
    "@types/node": "^20",
