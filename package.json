    "check:task-logic": "node scripts/check-task-logic.mjs",
    "check:task-scale": "node scripts/check-task-scale.mjs",
    "check:rls": "node scripts/validate-rls.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
